// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Event {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?
  quota          Int?
  formSchema     String
  requireProof   Boolean  @default(false)
  createdByName  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tickets      Ticket[]
}


model Ticket {
  id              String   @id @default(uuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])
  
  registrantName  String
  registrantEmail String
  
  formData        String   // JSON string of the submitted answers
  paymentProofUrl String?  // URL to the uploaded payment proof, if required
  
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  scanStatus      String   @default("BELUM_HADIR") // BELUM_HADIR, MASUK, KELUAR
  
  qrCodeToken     String?  @unique // Encrypted token for QR
  orderId         String?  // Field to group multiple tickets from one checkout
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scanLogs        ScanLog[]

  @@index([eventId, createdAt])
  @@index([eventId, registrantEmail])
  @@index([eventId, status])
  @@index([eventId, scanStatus])
  @@index([orderId])
}

model ScanLog {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  
  action      String   // MASUK, KELUAR
  scannedAt   DateTime @default(now())
  scannedBy   String   // Admin identifier or name

  @@index([ticketId, scannedAt])
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String   // bcrypt hashed
  name      String
  role      String   @default("PETUGAS") // OWNER, ADMIN, PANITIA, PETUGAS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
